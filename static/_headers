# Netlify response headers. Served from static/, so Hugo copies this to the
# site root verbatim.
#
# Netlify already edge-caches the HTML itself and purges the edge atomically on
# every deploy, so there is nothing to configure for pages — only for the
# long-lived assets below.

# Fonts never change: the filename encodes family, weight, style and subset, and
# a different font would be a different file. Safe to cache forever. This is what
# makes self-hosting them pay off — a repeat visitor fetches zero font bytes.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Images and the walkthrough video: long, but NOT immutable — these could be
# re-exported under the same name.
/images/*
  Cache-Control: public, max-age=2592000

# The stylesheet is content-hashed by Hugo (/css/style.min.<hash>.css), so a change
# to it produces a different URL. That makes a stale hit impossible and lets this be
# cached forever — the same reasoning as /fonts/* above.
/css/*
  Cache-Control: public, max-age=31536000, immutable

# Root-level statics (favicons, apple-touch-icon, og-image): a day, so a
# re-export under the same name still propagates quickly.
/favicon.svg
  Cache-Control: public, max-age=86400
/favicon-32.png
  Cache-Control: public, max-age=86400
/apple-touch-icon.png
  Cache-Control: public, max-age=86400
/og-image.png
  Cache-Control: public, max-age=86400

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
