# Old WordPress site archive — ~7.4 GB combined, and ajency.tar alone is 2.2 GB,
# far over GitHub's 100 MB per-file hard limit. Not part of the Hugo site.
ajency/
ajency.tar

# Build output — Netlify runs `hugo --gc --minify` itself (see netlify.toml).
# Keeping this out of git is also what stops a stray `hugo server` build
# (which rewrites URLs to localhost:1313) from ever reaching production.
public/
.hugo_build.lock
resources/_gen/

# macOS
.DS_Store

# Machine-local, per the convention in ~/.claude/CLAUDE.md
.claude/settings.local.json
.claude/CLAUDE.local.md

# Local Netlify folder
.netlify

# claude-seo (github.com/AgriciDaniel/claude-seo, MIT) — vendored third-party
# skills + agents, installed project-local so they don't load in every other
# project under ~/passport. Untracked deliberately: this repo is public, and the
# "project skills are shared" convention is for skills we wrote, not 300 files of
# someone else's. Reinstall: bash claude-seo/install.sh, then move seo* here.
# .venv is a Python venv (absolute shebangs — never relocatable, always rebuild).
.claude/skills/seo/
.claude/skills/seo-*/
.claude/agents/seo-*.md

# Design-sync (claude.ai/design) — staged converter scripts, generated build
# output, and machine state. The durable inputs (design-system/ source,
# .design-sync/config.json, NOTES.md, conventions.md, previews/) ARE tracked.
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules
design-system/node_modules/
design-system/dist/
design-system/styles/
